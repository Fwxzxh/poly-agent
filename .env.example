# Poly Agent Configuration

# Required: Your Google AI API Key
GOOGLE_API_KEY=your_api_key_here

# Optional: Gemini Model to use
# Default: gemini-3.1-flash-lite-preview
# GOOGLE_MODEL=gemini-2.0-flash-exp

# Optional: Enable internal debug logs (raw requests/responses)
DEBUG=false

# Optional: Enable verbose output for tool results in CLI
VERBOSE=false

# Optional: Enable response streaming
STREAMING=false
